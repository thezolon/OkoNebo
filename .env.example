# Copy this file to .env and fill in your own keys.
# These override config.yaml secrets at runtime.

OWM_API_KEY=
PWS_API_KEY=

# Optional auth bootstrap (recommended when enabling auth)
AUTH_ENABLED=false
AUTH_REQUIRE_VIEWER_LOGIN=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=

# Note: ADMIN_/VIEWER_ values are bootstrap defaults only.
# If auth users already exist in secure_settings.db, those persisted users are used.

# Optional token signing override
AUTH_TOKEN_SECRET=
